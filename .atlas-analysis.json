  "keyFeatures": [
    "13 specialized AI agents for delegated tasks (planner, code-reviewer, security-reviewer, tdd-guide, etc.)",
    "50+ reusable skills covering TDD, security, patterns, continuous learning, and domain-specific workflows",
    "33 slash commands for quick execution of common development workflows",
    "Hook-based automation system with 8+ event types for session management and quality enforcement",
    "Multi-platform support for Claude Code, Cursor IDE, Codex CLI, and OpenCode",
    "Continuous learning system v2 with instinct-based pattern extraction and evolution",
    "Security scanning integration with AgentShield for vulnerability detection",
    "Cross-platform Node.js hooks and scripts for Windows, macOS, and Linux",
    "Multi-language rule sets (TypeScript, Python, Go, Swift, C++, Java)",
    "Token optimization strategies and context management tools"
  ],
  "publicApiSurface": [
    "/plan - Create implementation plans with planner agent",
    "/tdd - Enforce test-driven development workflow",
    "/code-review - Review code for quality and security",
    "/security-scan - Run AgentShield security audit",
    "/build-fix - Fix build and type errors",
    "/e2e - Generate and run Playwright E2E tests",
    "/refactor-clean - Remove dead code and duplicates",
    "/learn - Extract patterns from session",
    "/instinct-status - View learned instincts",
    "/evolve - Cluster instincts into skills",
    "/orchestrate - Multi-agent workflow coordination",
    "/verify - Run verification loop",
    "/checkpoint - Save verification state",
    "/go-review - Go code review",
    "/python-review - Python code review",
    "planner agent - Implementation planning specialist",
    "architect agent - System design and scalability",
    "tdd-guide agent - Test-driven development enforcer",
    "code-reviewer agent - Quality and maintainability reviewer",
    "security-reviewer agent - Vulnerability detection specialist",
    "tdd-workflow skill - TDD methodology with 80%+ coverage",
    "security-review skill - Comprehensive security checklist",
    "coding-standards skill - Universal coding standards",
    "continuous-learning-v2 skill - Instinct-based learning system",
    "strategic-compact skill - Context management and compaction",
    "SessionStart hook - Memory persistence and context loading",
    "PostToolUse hook - Auto-formatting and quality checks",
    "PreCompact hook - Pre-compaction state saving"
  ]
